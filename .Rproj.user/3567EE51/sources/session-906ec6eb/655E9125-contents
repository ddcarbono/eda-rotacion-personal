## Resumen de resultados inferenciales

```{r resumen-inferencial}
tibble(
  Variable          = c("Edad", "Antigüedad", "Tipo de personal", 
                        "Género", "Tipo de contrato"),
  Prueba            = c("Wilcoxon-Mann-Whitney", "Wilcoxon-Mann-Whitney",
                        "Chi-cuadrado", "Chi-cuadrado", "Chi-cuadrado"),
  `P-valor`         = c(
    ifelse(test_edad$p.value  < 0.001, "< 0.001", round(test_edad$p.value, 3)),
    ifelse(test_antig$p.value < 0.001, "< 0.001", round(test_antig$p.value, 3)),
    ifelse(test_tp$p.value    < 0.001, "< 0.001", round(test_tp$p.value, 3)),
    ifelse(test_gen$p.value   < 0.001, "< 0.001", round(test_gen$p.value, 3)),
    ifelse(test_con$p.value   < 0.001, "< 0.001", round(test_con$p.value, 3))
  ),
  Conclusión        = c(
    ifelse(test_edad$p.value  < 0.05, "Diferencia significativa", "Sin diferencia significativa"),
    ifelse(test_antig$p.value < 0.05, "Diferencia significativa", "Sin diferencia significativa"),
    ifelse(test_tp$p.value    < 0.05, "Asociación significativa", "Sin asociación significativa"),
    ifelse(test_gen$p.value   < 0.05, "Asociación significativa", "Sin asociación significativa"),
    ifelse(test_con$p.value   < 0.05, "Asociación significativa", "Sin asociación significativa")
  )
) %>%
  kable(caption = "Resumen de pruebas de hipótesis") %>%
  kable_styling(bootstrap_options = c("striped", "hover", "condensed"),
                full_width = FALSE)
```